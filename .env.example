# ---------------------------------------------------------------------------
# Firebase web config.
#
# These values are NOT secret — they are compiled into the public client
# bundle by design. Security is enforced by Firestore rules (see
# ARCHITECTURE.md#security), not by keeping these hidden.
#
# Copy this file to `.env` and fill in the values from your Firebase project
# (Project settings -> General -> "Your apps" -> SDK setup and configuration).
# For emulator-only local development you can leave most blank and keep the
# `demo-` project id below, which works fully offline.
# ---------------------------------------------------------------------------

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=demo-khatma
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# Local development
# ---------------------------------------------------------------------------

# Talk to the local Firestore emulator instead of your real Firestore.
#   true  -> always emulator (recommended while developing)
#   false -> always your real Firebase project, even during `npm run dev`
# Set this to false once you've filled in the VITE_FIREBASE_* values above and
# want to see the app talking to your real project.
VITE_USE_EMULATOR=true
VITE_EMULATOR_HOST=127.0.0.1
VITE_EMULATOR_PORT=8080
