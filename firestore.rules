rules_version = '2';

// -----------------------------------------------------------------------------
// IMPORTANT: this app has NO authentication (REQUIREMENTS §3). These rules can
// only validate document SHAPE and reject unknown paths — they are NOT an
// identity boundary. Anyone with the public web config could write. That is the
// explicitly accepted, trust-based model (unguessable admin URL + community
// trust). See ARCHITECTURE.md#security before hardening.
// -----------------------------------------------------------------------------

service cloud.firestore {
  match /databases/{database}/documents {

    // Global roster of people.
    match /roster/{personId} {
      allow read: if true;
      allow create, update: if isValidPerson(request.resource.data);
      allow delete: if true;
    }

    // Khatmas and their per-member assignments.
    match /khatmas/{khatmaId} {
      allow read: if true;
      allow create, update: if isValidKhatma(request.resource.data);
      allow delete: if true;
      match /assignments/{memberId} {
        allow read: if true;
        allow create, update: if isValidAssignment(request.resource.data);
        allow delete: if true;
      }
    }

    // Global admin-editable content (du3a text).
    match /content/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Deny any path not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidPerson(d) {
      return d.name is string
        && d.name.size() > 0
        && d.completedPages is list
        && d.createdAt is number
        // Added in Stage 2 — optional so legacy docs still validate.
        && (!('pagesPerDay' in d) || d.pagesPerDay is number)
        && (!('enabled' in d) || d.enabled is bool);
    }

    // Shape-only (types kept lenient to match the client writes; these rules can
    // never enforce identity in this no-auth app — see ARCHITECTURE.md#security).
    // Khatmas are open-ended series (Stage 3): no start date or duration —
    // `remainingPages` + `roundCount` drive admin-triggered distribution rounds.
    function isValidKhatma(d) {
      return d.seriesId is string
        && d.seriesName is string
        && d.seriesNumber is number
        && d.totalPages is number
        && d.memberIds is list
        && d.anonymous is bool
        && d.status is string
        && d.remainingPages is list
        && d.roundCount is number
        && d.createdAt is number
        && (!('scope' in d) || d.scope is map)
        && (!('capacities' in d) || d.capacities is map)
        && (!('lastDistributionDate' in d) || d.lastDistributionDate is string)
        && (!('duaReciterId' in d) || d.duaReciterId is string)
        && (!('completedAt' in d) || d.completedAt is number);
    }

    function isValidAssignment(d) {
      return d.memberId is string
        && d.rounds is list
        && d.missedStreak is number;
    }
  }
}
