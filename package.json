{
  "name": "quran-khatma-tracker",
  "version": "0.1.0",
  "description": "Quran Khatma Tracker — a static, framework-free TypeScript app for organizing collective Quran readings, backed by Firebase/Firestore.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:react-spike": "tsc --noEmit && vite build --config vite.react-spike.config.ts",
    "check:bundle-budgets": "npm run build:react-spike && node scripts/check-bundle-budgets.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "emulators": "firebase emulators:start --only firestore",
    "emulators:kill": "node scripts/kill-emulators.mjs",
    "emulators:restart": "npm run emulators:kill && npm run emulators",
    "seed": "tsx scripts/seed-emulator.ts",
    "build:quran": "tsx scripts/build-quran-data.ts",
    "deploy:rules": "firebase deploy --only firestore:rules --project collectivekhatma --non-interactive"
  },
  "engines": {
    "node": "24.18.0"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^9.2.0",
    "@mui/material": "^9.2.0",
    "@reduxjs/toolkit": "^2.12.0",
    "firebase": "^12.16.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.1",
    "stylis": "^4.4.0",
    "stylis-plugin-rtl": "^2.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "firebase-admin": "^14.1.0",
    "firebase-tools": "^15.23.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "allowScripts": {
    "@firebase/util@1.15.1": true,
    "esbuild@0.28.1": true,
    "protobufjs@7.6.5": true,
    "re2@1.24.1": true
  }
}
