{"page":447,"juz":23,"surahIds":[37],"ayat":[{"surah":37,"ayah":25,"text":"مَا لَكُمْ لَا تَنَاصَرُونَ"},{"surah":37,"ayah":26,"text":"بَلْ هُمُ ٱلْيَوْمَ مُسْتَسْلِمُونَ"},{"surah":37,"ayah":27,"text":"وَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَسَآءَلُونَ"},{"surah":37,"ayah":28,"text":"قَالُوٓا۟ إِنَّكُمْ كُنتُمْ تَأْتُونَنَا عَنِ ٱلْيَمِينِ"},{"surah":37,"ayah":29,"text":"قَالُوا۟ بَل لَّمْ تَكُونُوا۟ مُؤْمِنِينَ"},{"surah":37,"ayah":30,"text":"وَمَا كَانَ لَنَا عَلَيْكُم مِّن سُلْطَـٰنٍۭ ۖ بَلْ كُنتُمْ قَوْمًا طَـٰغِينَ"},{"surah":37,"ayah":31,"text":"فَحَقَّ عَلَيْنَا قَوْلُ رَبِّنَآ ۖ إِنَّا لَذَآئِقُونَ"},{"surah":37,"ayah":32,"text":"فَأَغْوَيْنَـٰكُمْ إِنَّا كُنَّا غَـٰوِينَ"},{"surah":37,"ayah":33,"text":"فَإِنَّهُمْ يَوْمَئِذٍ فِى ٱلْعَذَابِ مُشْتَرِكُونَ"},{"surah":37,"ayah":34,"text":"إِنَّا كَذَٰلِكَ نَفْعَلُ بِٱلْمُجْرِمِينَ"},{"surah":37,"ayah":35,"text":"إِنَّهُمْ كَانُوٓا۟ إِذَا قِيلَ لَهُمْ لَآ إِلَـٰهَ إِلَّا ٱللَّهُ يَسْتَكْبِرُونَ"},{"surah":37,"ayah":36,"text":"وَيَقُولُونَ أَئِنَّا لَتَارِكُوٓا۟ ءَالِهَتِنَا لِشَاعِرٍ مَّجْنُونٍۭ"},{"surah":37,"ayah":37,"text":"بَلْ جَآءَ بِٱلْحَقِّ وَصَدَّقَ ٱلْمُرْسَلِينَ"},{"surah":37,"ayah":38,"text":"إِنَّكُمْ لَذَآئِقُوا۟ ٱلْعَذَابِ ٱلْأَلِيمِ"},{"surah":37,"ayah":39,"text":"وَمَا تُجْزَوْنَ إِلَّا مَا كُنتُمْ تَعْمَلُونَ"},{"surah":37,"ayah":40,"text":"إِلَّا عِبَادَ ٱللَّهِ ٱلْمُخْلَصِينَ"},{"surah":37,"ayah":41,"text":"أُو۟لَـٰٓئِكَ لَهُمْ رِزْقٌ مَّعْلُومٌ"},{"surah":37,"ayah":42,"text":"فَوَٰكِهُ ۖ وَهُم مُّكْرَمُونَ"},{"surah":37,"ayah":43,"text":"فِى جَنَّـٰتِ ٱلنَّعِيمِ"},{"surah":37,"ayah":44,"text":"عَلَىٰ سُرُرٍ مُّتَقَـٰبِلِينَ"},{"surah":37,"ayah":45,"text":"يُطَافُ عَلَيْهِم بِكَأْسٍ مِّن مَّعِينٍۭ"},{"surah":37,"ayah":46,"text":"بَيْضَآءَ لَذَّةٍ لِّلشَّـٰرِبِينَ"},{"surah":37,"ayah":47,"text":"لَا فِيهَا غَوْلٌ وَلَا هُمْ عَنْهَا يُنزَفُونَ"},{"surah":37,"ayah":48,"text":"وَعِندَهُمْ قَـٰصِرَٰتُ ٱلطَّرْفِ عِينٌ"},{"surah":37,"ayah":49,"text":"كَأَنَّهُنَّ بَيْضٌ مَّكْنُونٌ"},{"surah":37,"ayah":50,"text":"فَأَقْبَلَ بَعْضُهُمْ عَلَىٰ بَعْضٍ يَتَسَآءَلُونَ"},{"surah":37,"ayah":51,"text":"قَالَ قَآئِلٌ مِّنْهُمْ إِنِّى كَانَ لِى قَرِينٌ"}]}