{"page":534,"juz":27,"surahIds":[55,56],"ayat":[{"surah":55,"ayah":68,"text":"فِيهِمَا فَـٰكِهَةٌ وَنَخْلٌ وَرُمَّانٌ"},{"surah":55,"ayah":69,"text":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"surah":55,"ayah":70,"text":"فِيهِنَّ خَيْرَٰتٌ حِسَانٌ"},{"surah":55,"ayah":71,"text":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"surah":55,"ayah":72,"text":"حُورٌ مَّقْصُورَٰتٌ فِى ٱلْخِيَامِ"},{"surah":55,"ayah":73,"text":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"surah":55,"ayah":74,"text":"لَمْ يَطْمِثْهُنَّ إِنسٌ قَبْلَهُمْ وَلَا جَآنٌّ"},{"surah":55,"ayah":75,"text":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"surah":55,"ayah":76,"text":"مُتَّكِـِٔينَ عَلَىٰ رَفْرَفٍ خُضْرٍ وَعَبْقَرِىٍّ حِسَانٍ"},{"surah":55,"ayah":77,"text":"فَبِأَىِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ"},{"surah":55,"ayah":78,"text":"تَبَـٰرَكَ ٱسْمُ رَبِّكَ ذِى ٱلْجَلَـٰلِ وَٱلْإِكْرَامِ"},{"surah":56,"ayah":1,"text":"إِذَا وَقَعَتِ ٱلْوَاقِعَةُ"},{"surah":56,"ayah":2,"text":"لَيْسَ لِوَقْعَتِهَا كَاذِبَةٌ"},{"surah":56,"ayah":3,"text":"خَافِضَةٌ رَّافِعَةٌ"},{"surah":56,"ayah":4,"text":"إِذَا رُجَّتِ ٱلْأَرْضُ رَجًّا"},{"surah":56,"ayah":5,"text":"وَبُسَّتِ ٱلْجِبَالُ بَسًّا"},{"surah":56,"ayah":6,"text":"فَكَانَتْ هَبَآءً مُّنۢبَثًّا"},{"surah":56,"ayah":7,"text":"وَكُنتُمْ أَزْوَٰجًا ثَلَـٰثَةً"},{"surah":56,"ayah":8,"text":"فَأَصْحَـٰبُ ٱلْمَيْمَنَةِ مَآ أَصْحَـٰبُ ٱلْمَيْمَنَةِ"},{"surah":56,"ayah":9,"text":"وَأَصْحَـٰبُ ٱلْمَشْـَٔمَةِ مَآ أَصْحَـٰبُ ٱلْمَشْـَٔمَةِ"},{"surah":56,"ayah":10,"text":"وَٱلسَّـٰبِقُونَ ٱلسَّـٰبِقُونَ"},{"surah":56,"ayah":11,"text":"أُو۟لَـٰٓئِكَ ٱلْمُقَرَّبُونَ"},{"surah":56,"ayah":12,"text":"فِى جَنَّـٰتِ ٱلنَّعِيمِ"},{"surah":56,"ayah":13,"text":"ثُلَّةٌ مِّنَ ٱلْأَوَّلِينَ"},{"surah":56,"ayah":14,"text":"وَقَلِيلٌ مِّنَ ٱلْـَٔاخِرِينَ"},{"surah":56,"ayah":15,"text":"عَلَىٰ سُرُرٍ مَّوْضُونَةٍ"},{"surah":56,"ayah":16,"text":"مُّتَّكِـِٔينَ عَلَيْهَا مُتَقَـٰبِلِينَ"}]}