{"page":536,"juz":27,"surahIds":[56],"ayat":[{"surah":56,"ayah":51,"text":"ثُمَّ إِنَّكُمْ أَيُّهَا ٱلضَّآلُّونَ ٱلْمُكَذِّبُونَ"},{"surah":56,"ayah":52,"text":"لَـَٔاكِلُونَ مِن شَجَرٍ مِّن زَقُّومٍ"},{"surah":56,"ayah":53,"text":"فَمَالِـُٔونَ مِنْهَا ٱلْبُطُونَ"},{"surah":56,"ayah":54,"text":"فَشَـٰرِبُونَ عَلَيْهِ مِنَ ٱلْحَمِيمِ"},{"surah":56,"ayah":55,"text":"فَشَـٰرِبُونَ شُرْبَ ٱلْهِيمِ"},{"surah":56,"ayah":56,"text":"هَـٰذَا نُزُلُهُمْ يَوْمَ ٱلدِّينِ"},{"surah":56,"ayah":57,"text":"نَحْنُ خَلَقْنَـٰكُمْ فَلَوْلَا تُصَدِّقُونَ"},{"surah":56,"ayah":58,"text":"أَفَرَءَيْتُم مَّا تُمْنُونَ"},{"surah":56,"ayah":59,"text":"ءَأَنتُمْ تَخْلُقُونَهُۥٓ أَمْ نَحْنُ ٱلْخَـٰلِقُونَ"},{"surah":56,"ayah":60,"text":"نَحْنُ قَدَّرْنَا بَيْنَكُمُ ٱلْمَوْتَ وَمَا نَحْنُ بِمَسْبُوقِينَ"},{"surah":56,"ayah":61,"text":"عَلَىٰٓ أَن نُّبَدِّلَ أَمْثَـٰلَكُمْ وَنُنشِئَكُمْ فِى مَا لَا تَعْلَمُونَ"},{"surah":56,"ayah":62,"text":"وَلَقَدْ عَلِمْتُمُ ٱلنَّشْأَةَ ٱلْأُولَىٰ فَلَوْلَا تَذَكَّرُونَ"},{"surah":56,"ayah":63,"text":"أَفَرَءَيْتُم مَّا تَحْرُثُونَ"},{"surah":56,"ayah":64,"text":"ءَأَنتُمْ تَزْرَعُونَهُۥٓ أَمْ نَحْنُ ٱلزَّٰرِعُونَ"},{"surah":56,"ayah":65,"text":"لَوْ نَشَآءُ لَجَعَلْنَـٰهُ حُطَـٰمًا فَظَلْتُمْ تَفَكَّهُونَ"},{"surah":56,"ayah":66,"text":"إِنَّا لَمُغْرَمُونَ"},{"surah":56,"ayah":67,"text":"بَلْ نَحْنُ مَحْرُومُونَ"},{"surah":56,"ayah":68,"text":"أَفَرَءَيْتُمُ ٱلْمَآءَ ٱلَّذِى تَشْرَبُونَ"},{"surah":56,"ayah":69,"text":"ءَأَنتُمْ أَنزَلْتُمُوهُ مِنَ ٱلْمُزْنِ أَمْ نَحْنُ ٱلْمُنزِلُونَ"},{"surah":56,"ayah":70,"text":"لَوْ نَشَآءُ جَعَلْنَـٰهُ أُجَاجًا فَلَوْلَا تَشْكُرُونَ"},{"surah":56,"ayah":71,"text":"أَفَرَءَيْتُمُ ٱلنَّارَ ٱلَّتِى تُورُونَ"},{"surah":56,"ayah":72,"text":"ءَأَنتُمْ أَنشَأْتُمْ شَجَرَتَهَآ أَمْ نَحْنُ ٱلْمُنشِـُٔونَ"},{"surah":56,"ayah":73,"text":"نَحْنُ جَعَلْنَـٰهَا تَذْكِرَةً وَمَتَـٰعًا لِّلْمُقْوِينَ"},{"surah":56,"ayah":74,"text":"فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ"},{"surah":56,"ayah":75,"text":"۞ فَلَآ أُقْسِمُ بِمَوَٰقِعِ ٱلنُّجُومِ"},{"surah":56,"ayah":76,"text":"وَإِنَّهُۥ لَقَسَمٌ لَّوْ تَعْلَمُونَ عَظِيمٌ"}]}