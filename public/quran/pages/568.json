{"page":568,"juz":29,"surahIds":[69,70],"ayat":[{"surah":69,"ayah":35,"text":"فَلَيْسَ لَهُ ٱلْيَوْمَ هَـٰهُنَا حَمِيمٌ"},{"surah":69,"ayah":36,"text":"وَلَا طَعَامٌ إِلَّا مِنْ غِسْلِينٍ"},{"surah":69,"ayah":37,"text":"لَّا يَأْكُلُهُۥٓ إِلَّا ٱلْخَـٰطِـُٔونَ"},{"surah":69,"ayah":38,"text":"فَلَآ أُقْسِمُ بِمَا تُبْصِرُونَ"},{"surah":69,"ayah":39,"text":"وَمَا لَا تُبْصِرُونَ"},{"surah":69,"ayah":40,"text":"إِنَّهُۥ لَقَوْلُ رَسُولٍ كَرِيمٍ"},{"surah":69,"ayah":41,"text":"وَمَا هُوَ بِقَوْلِ شَاعِرٍ ۚ قَلِيلًا مَّا تُؤْمِنُونَ"},{"surah":69,"ayah":42,"text":"وَلَا بِقَوْلِ كَاهِنٍ ۚ قَلِيلًا مَّا تَذَكَّرُونَ"},{"surah":69,"ayah":43,"text":"تَنزِيلٌ مِّن رَّبِّ ٱلْعَـٰلَمِينَ"},{"surah":69,"ayah":44,"text":"وَلَوْ تَقَوَّلَ عَلَيْنَا بَعْضَ ٱلْأَقَاوِيلِ"},{"surah":69,"ayah":45,"text":"لَأَخَذْنَا مِنْهُ بِٱلْيَمِينِ"},{"surah":69,"ayah":46,"text":"ثُمَّ لَقَطَعْنَا مِنْهُ ٱلْوَتِينَ"},{"surah":69,"ayah":47,"text":"فَمَا مِنكُم مِّنْ أَحَدٍ عَنْهُ حَـٰجِزِينَ"},{"surah":69,"ayah":48,"text":"وَإِنَّهُۥ لَتَذْكِرَةٌ لِّلْمُتَّقِينَ"},{"surah":69,"ayah":49,"text":"وَإِنَّا لَنَعْلَمُ أَنَّ مِنكُم مُّكَذِّبِينَ"},{"surah":69,"ayah":50,"text":"وَإِنَّهُۥ لَحَسْرَةٌ عَلَى ٱلْكَـٰفِرِينَ"},{"surah":69,"ayah":51,"text":"وَإِنَّهُۥ لَحَقُّ ٱلْيَقِينِ"},{"surah":69,"ayah":52,"text":"فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ"},{"surah":70,"ayah":1,"text":"سَأَلَ سَآئِلٌۢ بِعَذَابٍ وَاقِعٍ"},{"surah":70,"ayah":2,"text":"لِّلْكَـٰفِرِينَ لَيْسَ لَهُۥ دَافِعٌ"},{"surah":70,"ayah":3,"text":"مِّنَ ٱللَّهِ ذِى ٱلْمَعَارِجِ"},{"surah":70,"ayah":4,"text":"تَعْرُجُ ٱلْمَلَـٰٓئِكَةُ وَٱلرُّوحُ إِلَيْهِ فِى يَوْمٍ كَانَ مِقْدَارُهُۥ خَمْسِينَ أَلْفَ سَنَةٍ"},{"surah":70,"ayah":5,"text":"فَٱصْبِرْ صَبْرًا جَمِيلًا"},{"surah":70,"ayah":6,"text":"إِنَّهُمْ يَرَوْنَهُۥ بَعِيدًا"},{"surah":70,"ayah":7,"text":"وَنَرَىٰهُ قَرِيبًا"},{"surah":70,"ayah":8,"text":"يَوْمَ تَكُونُ ٱلسَّمَآءُ كَٱلْمُهْلِ"},{"surah":70,"ayah":9,"text":"وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ"},{"surah":70,"ayah":10,"text":"وَلَا يَسْـَٔلُ حَمِيمٌ حَمِيمًا"}]}