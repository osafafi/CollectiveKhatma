{"page":569,"juz":29,"surahIds":[70],"ayat":[{"surah":70,"ayah":11,"text":"يُبَصَّرُونَهُمْ ۚ يَوَدُّ ٱلْمُجْرِمُ لَوْ يَفْتَدِى مِنْ عَذَابِ يَوْمِئِذٍۭ بِبَنِيهِ"},{"surah":70,"ayah":12,"text":"وَصَـٰحِبَتِهِۦ وَأَخِيهِ"},{"surah":70,"ayah":13,"text":"وَفَصِيلَتِهِ ٱلَّتِى تُـْٔوِيهِ"},{"surah":70,"ayah":14,"text":"وَمَن فِى ٱلْأَرْضِ جَمِيعًا ثُمَّ يُنجِيهِ"},{"surah":70,"ayah":15,"text":"كَلَّآ ۖ إِنَّهَا لَظَىٰ"},{"surah":70,"ayah":16,"text":"نَزَّاعَةً لِّلشَّوَىٰ"},{"surah":70,"ayah":17,"text":"تَدْعُوا۟ مَنْ أَدْبَرَ وَتَوَلَّىٰ"},{"surah":70,"ayah":18,"text":"وَجَمَعَ فَأَوْعَىٰٓ"},{"surah":70,"ayah":19,"text":"۞ إِنَّ ٱلْإِنسَـٰنَ خُلِقَ هَلُوعًا"},{"surah":70,"ayah":20,"text":"إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعًا"},{"surah":70,"ayah":21,"text":"وَإِذَا مَسَّهُ ٱلْخَيْرُ مَنُوعًا"},{"surah":70,"ayah":22,"text":"إِلَّا ٱلْمُصَلِّينَ"},{"surah":70,"ayah":23,"text":"ٱلَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ دَآئِمُونَ"},{"surah":70,"ayah":24,"text":"وَٱلَّذِينَ فِىٓ أَمْوَٰلِهِمْ حَقٌّ مَّعْلُومٌ"},{"surah":70,"ayah":25,"text":"لِّلسَّآئِلِ وَٱلْمَحْرُومِ"},{"surah":70,"ayah":26,"text":"وَٱلَّذِينَ يُصَدِّقُونَ بِيَوْمِ ٱلدِّينِ"},{"surah":70,"ayah":27,"text":"وَٱلَّذِينَ هُم مِّنْ عَذَابِ رَبِّهِم مُّشْفِقُونَ"},{"surah":70,"ayah":28,"text":"إِنَّ عَذَابَ رَبِّهِمْ غَيْرُ مَأْمُونٍ"},{"surah":70,"ayah":29,"text":"وَٱلَّذِينَ هُمْ لِفُرُوجِهِمْ حَـٰفِظُونَ"},{"surah":70,"ayah":30,"text":"إِلَّا عَلَىٰٓ أَزْوَٰجِهِمْ أَوْ مَا مَلَكَتْ أَيْمَـٰنُهُمْ فَإِنَّهُمْ غَيْرُ مَلُومِينَ"},{"surah":70,"ayah":31,"text":"فَمَنِ ٱبْتَغَىٰ وَرَآءَ ذَٰلِكَ فَأُو۟لَـٰٓئِكَ هُمُ ٱلْعَادُونَ"},{"surah":70,"ayah":32,"text":"وَٱلَّذِينَ هُمْ لِأَمَـٰنَـٰتِهِمْ وَعَهْدِهِمْ رَٰعُونَ"},{"surah":70,"ayah":33,"text":"وَٱلَّذِينَ هُم بِشَهَـٰدَٰتِهِمْ قَآئِمُونَ"},{"surah":70,"ayah":34,"text":"وَٱلَّذِينَ هُمْ عَلَىٰ صَلَاتِهِمْ يُحَافِظُونَ"},{"surah":70,"ayah":35,"text":"أُو۟لَـٰٓئِكَ فِى جَنَّـٰتٍ مُّكْرَمُونَ"},{"surah":70,"ayah":36,"text":"فَمَالِ ٱلَّذِينَ كَفَرُوا۟ قِبَلَكَ مُهْطِعِينَ"},{"surah":70,"ayah":37,"text":"عَنِ ٱلْيَمِينِ وَعَنِ ٱلشِّمَالِ عِزِينَ"},{"surah":70,"ayah":38,"text":"أَيَطْمَعُ كُلُّ ٱمْرِئٍ مِّنْهُمْ أَن يُدْخَلَ جَنَّةَ نَعِيمٍ"},{"surah":70,"ayah":39,"text":"كَلَّآ ۖ إِنَّا خَلَقْنَـٰهُم مِّمَّا يَعْلَمُونَ"}]}