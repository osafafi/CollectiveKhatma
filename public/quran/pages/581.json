{"page":581,"juz":29,"surahIds":[77],"ayat":[{"surah":77,"ayah":20,"text":"أَلَمْ نَخْلُقكُّم مِّن مَّآءٍ مَّهِينٍ"},{"surah":77,"ayah":21,"text":"فَجَعَلْنَـٰهُ فِى قَرَارٍ مَّكِينٍ"},{"surah":77,"ayah":22,"text":"إِلَىٰ قَدَرٍ مَّعْلُومٍ"},{"surah":77,"ayah":23,"text":"فَقَدَرْنَا فَنِعْمَ ٱلْقَـٰدِرُونَ"},{"surah":77,"ayah":24,"text":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"},{"surah":77,"ayah":25,"text":"أَلَمْ نَجْعَلِ ٱلْأَرْضَ كِفَاتًا"},{"surah":77,"ayah":26,"text":"أَحْيَآءً وَأَمْوَٰتًا"},{"surah":77,"ayah":27,"text":"وَجَعَلْنَا فِيهَا رَوَٰسِىَ شَـٰمِخَـٰتٍ وَأَسْقَيْنَـٰكُم مَّآءً فُرَاتًا"},{"surah":77,"ayah":28,"text":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"},{"surah":77,"ayah":29,"text":"ٱنطَلِقُوٓا۟ إِلَىٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ"},{"surah":77,"ayah":30,"text":"ٱنطَلِقُوٓا۟ إِلَىٰ ظِلٍّ ذِى ثَلَـٰثِ شُعَبٍ"},{"surah":77,"ayah":31,"text":"لَّا ظَلِيلٍ وَلَا يُغْنِى مِنَ ٱللَّهَبِ"},{"surah":77,"ayah":32,"text":"إِنَّهَا تَرْمِى بِشَرَرٍ كَٱلْقَصْرِ"},{"surah":77,"ayah":33,"text":"كَأَنَّهُۥ جِمَـٰلَتٌ صُفْرٌ"},{"surah":77,"ayah":34,"text":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"},{"surah":77,"ayah":35,"text":"هَـٰذَا يَوْمُ لَا يَنطِقُونَ"},{"surah":77,"ayah":36,"text":"وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ"},{"surah":77,"ayah":37,"text":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"},{"surah":77,"ayah":38,"text":"هَـٰذَا يَوْمُ ٱلْفَصْلِ ۖ جَمَعْنَـٰكُمْ وَٱلْأَوَّلِينَ"},{"surah":77,"ayah":39,"text":"فَإِن كَانَ لَكُمْ كَيْدٌ فَكِيدُونِ"},{"surah":77,"ayah":40,"text":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"},{"surah":77,"ayah":41,"text":"إِنَّ ٱلْمُتَّقِينَ فِى ظِلَـٰلٍ وَعُيُونٍ"},{"surah":77,"ayah":42,"text":"وَفَوَٰكِهَ مِمَّا يَشْتَهُونَ"},{"surah":77,"ayah":43,"text":"كُلُوا۟ وَٱشْرَبُوا۟ هَنِيٓـًٔۢا بِمَا كُنتُمْ تَعْمَلُونَ"},{"surah":77,"ayah":44,"text":"إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ"},{"surah":77,"ayah":45,"text":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"},{"surah":77,"ayah":46,"text":"كُلُوا۟ وَتَمَتَّعُوا۟ قَلِيلًا إِنَّكُم مُّجْرِمُونَ"},{"surah":77,"ayah":47,"text":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"},{"surah":77,"ayah":48,"text":"وَإِذَا قِيلَ لَهُمُ ٱرْكَعُوا۟ لَا يَرْكَعُونَ"},{"surah":77,"ayah":49,"text":"وَيْلٌ يَوْمَئِذٍ لِّلْمُكَذِّبِينَ"},{"surah":77,"ayah":50,"text":"فَبِأَىِّ حَدِيثٍۭ بَعْدَهُۥ يُؤْمِنُونَ"}]}