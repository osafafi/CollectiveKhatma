{"page":592,"juz":30,"surahIds":[87,88],"ayat":[{"surah":87,"ayah":16,"text":"بَلْ تُؤْثِرُونَ ٱلْحَيَوٰةَ ٱلدُّنْيَا"},{"surah":87,"ayah":17,"text":"وَٱلْـَٔاخِرَةُ خَيْرٌ وَأَبْقَىٰٓ"},{"surah":87,"ayah":18,"text":"إِنَّ هَـٰذَا لَفِى ٱلصُّحُفِ ٱلْأُولَىٰ"},{"surah":87,"ayah":19,"text":"صُحُفِ إِبْرَٰهِيمَ وَمُوسَىٰ"},{"surah":88,"ayah":1,"text":"هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَـٰشِيَةِ"},{"surah":88,"ayah":2,"text":"وُجُوهٌ يَوْمَئِذٍ خَـٰشِعَةٌ"},{"surah":88,"ayah":3,"text":"عَامِلَةٌ نَّاصِبَةٌ"},{"surah":88,"ayah":4,"text":"تَصْلَىٰ نَارًا حَامِيَةً"},{"surah":88,"ayah":5,"text":"تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍ"},{"surah":88,"ayah":6,"text":"لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍ"},{"surah":88,"ayah":7,"text":"لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍ"},{"surah":88,"ayah":8,"text":"وُجُوهٌ يَوْمَئِذٍ نَّاعِمَةٌ"},{"surah":88,"ayah":9,"text":"لِّسَعْيِهَا رَاضِيَةٌ"},{"surah":88,"ayah":10,"text":"فِى جَنَّةٍ عَالِيَةٍ"},{"surah":88,"ayah":11,"text":"لَّا تَسْمَعُ فِيهَا لَـٰغِيَةً"},{"surah":88,"ayah":12,"text":"فِيهَا عَيْنٌ جَارِيَةٌ"},{"surah":88,"ayah":13,"text":"فِيهَا سُرُرٌ مَّرْفُوعَةٌ"},{"surah":88,"ayah":14,"text":"وَأَكْوَابٌ مَّوْضُوعَةٌ"},{"surah":88,"ayah":15,"text":"وَنَمَارِقُ مَصْفُوفَةٌ"},{"surah":88,"ayah":16,"text":"وَزَرَابِىُّ مَبْثُوثَةٌ"},{"surah":88,"ayah":17,"text":"أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ"},{"surah":88,"ayah":18,"text":"وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ"},{"surah":88,"ayah":19,"text":"وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ"},{"surah":88,"ayah":20,"text":"وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ"},{"surah":88,"ayah":21,"text":"فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌ"},{"surah":88,"ayah":22,"text":"لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ"},{"surah":88,"ayah":23,"text":"إِلَّا مَن تَوَلَّىٰ وَكَفَرَ"},{"surah":88,"ayah":24,"text":"فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ"},{"surah":88,"ayah":25,"text":"إِنَّ إِلَيْنَآ إِيَابَهُمْ"},{"surah":88,"ayah":26,"text":"ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم"}]}