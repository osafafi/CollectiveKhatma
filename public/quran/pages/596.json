{"page":596,"juz":30,"surahIds":[92,93,94],"ayat":[{"surah":92,"ayah":15,"text":"لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى"},{"surah":92,"ayah":16,"text":"ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ"},{"surah":92,"ayah":17,"text":"وَسَيُجَنَّبُهَا ٱلْأَتْقَى"},{"surah":92,"ayah":18,"text":"ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ"},{"surah":92,"ayah":19,"text":"وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍ تُجْزَىٰٓ"},{"surah":92,"ayah":20,"text":"إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ"},{"surah":92,"ayah":21,"text":"وَلَسَوْفَ يَرْضَىٰ"},{"surah":93,"ayah":1,"text":"وَٱلضُّحَىٰ"},{"surah":93,"ayah":2,"text":"وَٱلَّيْلِ إِذَا سَجَىٰ"},{"surah":93,"ayah":3,"text":"مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ"},{"surah":93,"ayah":4,"text":"وَلَلْـَٔاخِرَةُ خَيْرٌ لَّكَ مِنَ ٱلْأُولَىٰ"},{"surah":93,"ayah":5,"text":"وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْضَىٰٓ"},{"surah":93,"ayah":6,"text":"أَلَمْ يَجِدْكَ يَتِيمًا فَـَٔاوَىٰ"},{"surah":93,"ayah":7,"text":"وَوَجَدَكَ ضَآلًّا فَهَدَىٰ"},{"surah":93,"ayah":8,"text":"وَوَجَدَكَ عَآئِلًا فَأَغْنَىٰ"},{"surah":93,"ayah":9,"text":"فَأَمَّا ٱلْيَتِيمَ فَلَا تَقْهَرْ"},{"surah":93,"ayah":10,"text":"وَأَمَّا ٱلسَّآئِلَ فَلَا تَنْهَرْ"},{"surah":93,"ayah":11,"text":"وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثْ"},{"surah":94,"ayah":1,"text":"أَلَمْ نَشْرَحْ لَكَ صَدْرَكَ"},{"surah":94,"ayah":2,"text":"وَوَضَعْنَا عَنكَ وِزْرَكَ"},{"surah":94,"ayah":3,"text":"ٱلَّذِىٓ أَنقَضَ ظَهْرَكَ"},{"surah":94,"ayah":4,"text":"وَرَفَعْنَا لَكَ ذِكْرَكَ"},{"surah":94,"ayah":5,"text":"فَإِنَّ مَعَ ٱلْعُسْرِ يُسْرًا"},{"surah":94,"ayah":6,"text":"إِنَّ مَعَ ٱلْعُسْرِ يُسْرًا"},{"surah":94,"ayah":7,"text":"فَإِذَا فَرَغْتَ فَٱنصَبْ"},{"surah":94,"ayah":8,"text":"وَإِلَىٰ رَبِّكَ فَٱرْغَب"}]}