{"page":597,"juz":30,"surahIds":[95,96],"ayat":[{"surah":95,"ayah":1,"text":"وَٱلتِّينِ وَٱلزَّيْتُونِ"},{"surah":95,"ayah":2,"text":"وَطُورِ سِينِينَ"},{"surah":95,"ayah":3,"text":"وَهَـٰذَا ٱلْبَلَدِ ٱلْأَمِينِ"},{"surah":95,"ayah":4,"text":"لَقَدْ خَلَقْنَا ٱلْإِنسَـٰنَ فِىٓ أَحْسَنِ تَقْوِيمٍ"},{"surah":95,"ayah":5,"text":"ثُمَّ رَدَدْنَـٰهُ أَسْفَلَ سَـٰفِلِينَ"},{"surah":95,"ayah":6,"text":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ فَلَهُمْ أَجْرٌ غَيْرُ مَمْنُونٍ"},{"surah":95,"ayah":7,"text":"فَمَا يُكَذِّبُكَ بَعْدُ بِٱلدِّينِ"},{"surah":95,"ayah":8,"text":"أَلَيْسَ ٱللَّهُ بِأَحْكَمِ ٱلْحَـٰكِمِينَ"},{"surah":96,"ayah":1,"text":"ٱقْرَأْ بِٱسْمِ رَبِّكَ ٱلَّذِى خَلَقَ"},{"surah":96,"ayah":2,"text":"خَلَقَ ٱلْإِنسَـٰنَ مِنْ عَلَقٍ"},{"surah":96,"ayah":3,"text":"ٱقْرَأْ وَرَبُّكَ ٱلْأَكْرَمُ"},{"surah":96,"ayah":4,"text":"ٱلَّذِى عَلَّمَ بِٱلْقَلَمِ"},{"surah":96,"ayah":5,"text":"عَلَّمَ ٱلْإِنسَـٰنَ مَا لَمْ يَعْلَمْ"},{"surah":96,"ayah":6,"text":"كَلَّآ إِنَّ ٱلْإِنسَـٰنَ لَيَطْغَىٰٓ"},{"surah":96,"ayah":7,"text":"أَن رَّءَاهُ ٱسْتَغْنَىٰٓ"},{"surah":96,"ayah":8,"text":"إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجْعَىٰٓ"},{"surah":96,"ayah":9,"text":"أَرَءَيْتَ ٱلَّذِى يَنْهَىٰ"},{"surah":96,"ayah":10,"text":"عَبْدًا إِذَا صَلَّىٰٓ"},{"surah":96,"ayah":11,"text":"أَرَءَيْتَ إِن كَانَ عَلَى ٱلْهُدَىٰٓ"},{"surah":96,"ayah":12,"text":"أَوْ أَمَرَ بِٱلتَّقْوَىٰٓ"},{"surah":96,"ayah":13,"text":"أَرَءَيْتَ إِن كَذَّبَ وَتَوَلَّىٰٓ"},{"surah":96,"ayah":14,"text":"أَلَمْ يَعْلَم بِأَنَّ ٱللَّهَ يَرَىٰ"},{"surah":96,"ayah":15,"text":"كَلَّا لَئِن لَّمْ يَنتَهِ لَنَسْفَعًۢا بِٱلنَّاصِيَةِ"},{"surah":96,"ayah":16,"text":"نَاصِيَةٍ كَـٰذِبَةٍ خَاطِئَةٍ"},{"surah":96,"ayah":17,"text":"فَلْيَدْعُ نَادِيَهُۥ"},{"surah":96,"ayah":18,"text":"سَنَدْعُ ٱلزَّبَانِيَةَ"},{"surah":96,"ayah":19,"text":"كَلَّا لَا تُطِعْهُ وَٱسْجُدْ وَٱقْتَرِب ۩","sajda":true}]}