{"page":600,"juz":30,"surahIds":[100,101,102],"ayat":[{"surah":100,"ayah":10,"text":"وَحُصِّلَ مَا فِى ٱلصُّدُورِ"},{"surah":100,"ayah":11,"text":"إِنَّ رَبَّهُم بِهِمْ يَوْمَئِذٍ لَّخَبِيرٌۢ"},{"surah":101,"ayah":1,"text":"ٱلْقَارِعَةُ"},{"surah":101,"ayah":2,"text":"مَا ٱلْقَارِعَةُ"},{"surah":101,"ayah":3,"text":"وَمَآ أَدْرَىٰكَ مَا ٱلْقَارِعَةُ"},{"surah":101,"ayah":4,"text":"يَوْمَ يَكُونُ ٱلنَّاسُ كَٱلْفَرَاشِ ٱلْمَبْثُوثِ"},{"surah":101,"ayah":5,"text":"وَتَكُونُ ٱلْجِبَالُ كَٱلْعِهْنِ ٱلْمَنفُوشِ"},{"surah":101,"ayah":6,"text":"فَأَمَّا مَن ثَقُلَتْ مَوَٰزِينُهُۥ"},{"surah":101,"ayah":7,"text":"فَهُوَ فِى عِيشَةٍ رَّاضِيَةٍ"},{"surah":101,"ayah":8,"text":"وَأَمَّا مَنْ خَفَّتْ مَوَٰزِينُهُۥ"},{"surah":101,"ayah":9,"text":"فَأُمُّهُۥ هَاوِيَةٌ"},{"surah":101,"ayah":10,"text":"وَمَآ أَدْرَىٰكَ مَا هِيَهْ"},{"surah":101,"ayah":11,"text":"نَارٌ حَامِيَةٌۢ"},{"surah":102,"ayah":1,"text":"أَلْهَىٰكُمُ ٱلتَّكَاثُرُ"},{"surah":102,"ayah":2,"text":"حَتَّىٰ زُرْتُمُ ٱلْمَقَابِرَ"},{"surah":102,"ayah":3,"text":"كَلَّا سَوْفَ تَعْلَمُونَ"},{"surah":102,"ayah":4,"text":"ثُمَّ كَلَّا سَوْفَ تَعْلَمُونَ"},{"surah":102,"ayah":5,"text":"كَلَّا لَوْ تَعْلَمُونَ عِلْمَ ٱلْيَقِينِ"},{"surah":102,"ayah":6,"text":"لَتَرَوُنَّ ٱلْجَحِيمَ"},{"surah":102,"ayah":7,"text":"ثُمَّ لَتَرَوُنَّهَا عَيْنَ ٱلْيَقِينِ"},{"surah":102,"ayah":8,"text":"ثُمَّ لَتُسْـَٔلُنَّ يَوْمَئِذٍ عَنِ ٱلنَّعِيمِ"}]}