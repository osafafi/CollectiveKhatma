{"page":601,"juz":30,"surahIds":[103,104,105],"ayat":[{"surah":103,"ayah":1,"text":"وَٱلْعَصْرِ"},{"surah":103,"ayah":2,"text":"إِنَّ ٱلْإِنسَـٰنَ لَفِى خُسْرٍ"},{"surah":103,"ayah":3,"text":"إِلَّا ٱلَّذِينَ ءَامَنُوا۟ وَعَمِلُوا۟ ٱلصَّـٰلِحَـٰتِ وَتَوَاصَوْا۟ بِٱلْحَقِّ وَتَوَاصَوْا۟ بِٱلصَّبْرِ"},{"surah":104,"ayah":1,"text":"وَيْلٌ لِّكُلِّ هُمَزَةٍ لُّمَزَةٍ"},{"surah":104,"ayah":2,"text":"ٱلَّذِى جَمَعَ مَالًا وَعَدَّدَهُۥ"},{"surah":104,"ayah":3,"text":"يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ"},{"surah":104,"ayah":4,"text":"كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ"},{"surah":104,"ayah":5,"text":"وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ"},{"surah":104,"ayah":6,"text":"نَارُ ٱللَّهِ ٱلْمُوقَدَةُ"},{"surah":104,"ayah":7,"text":"ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ"},{"surah":104,"ayah":8,"text":"إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌ"},{"surah":104,"ayah":9,"text":"فِى عَمَدٍ مُّمَدَّدَةٍۭ"},{"surah":105,"ayah":1,"text":"أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَـٰبِ ٱلْفِيلِ"},{"surah":105,"ayah":2,"text":"أَلَمْ يَجْعَلْ كَيْدَهُمْ فِى تَضْلِيلٍ"},{"surah":105,"ayah":3,"text":"وَأَرْسَلَ عَلَيْهِمْ طَيْرًا أَبَابِيلَ"},{"surah":105,"ayah":4,"text":"تَرْمِيهِم بِحِجَارَةٍ مِّن سِجِّيلٍ"},{"surah":105,"ayah":5,"text":"فَجَعَلَهُمْ كَعَصْفٍ مَّأْكُولٍۭ"}]}