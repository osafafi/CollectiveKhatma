{"page":602,"juz":30,"surahIds":[106,107,108],"ayat":[{"surah":106,"ayah":1,"text":"لِإِيلَـٰفِ قُرَيْشٍ"},{"surah":106,"ayah":2,"text":"إِۦلَـٰفِهِمْ رِحْلَةَ ٱلشِّتَآءِ وَٱلصَّيْفِ"},{"surah":106,"ayah":3,"text":"فَلْيَعْبُدُوا۟ رَبَّ هَـٰذَا ٱلْبَيْتِ"},{"surah":106,"ayah":4,"text":"ٱلَّذِىٓ أَطْعَمَهُم مِّن جُوعٍ وَءَامَنَهُم مِّنْ خَوْفٍۭ"},{"surah":107,"ayah":1,"text":"أَرَءَيْتَ ٱلَّذِى يُكَذِّبُ بِٱلدِّينِ"},{"surah":107,"ayah":2,"text":"فَذَٰلِكَ ٱلَّذِى يَدُعُّ ٱلْيَتِيمَ"},{"surah":107,"ayah":3,"text":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلْمِسْكِينِ"},{"surah":107,"ayah":4,"text":"فَوَيْلٌ لِّلْمُصَلِّينَ"},{"surah":107,"ayah":5,"text":"ٱلَّذِينَ هُمْ عَن صَلَاتِهِمْ سَاهُونَ"},{"surah":107,"ayah":6,"text":"ٱلَّذِينَ هُمْ يُرَآءُونَ"},{"surah":107,"ayah":7,"text":"وَيَمْنَعُونَ ٱلْمَاعُونَ"},{"surah":108,"ayah":1,"text":"إِنَّآ أَعْطَيْنَـٰكَ ٱلْكَوْثَرَ"},{"surah":108,"ayah":2,"text":"فَصَلِّ لِرَبِّكَ وَٱنْحَرْ"},{"surah":108,"ayah":3,"text":"إِنَّ شَانِئَكَ هُوَ ٱلْأَبْتَرُ"}]}