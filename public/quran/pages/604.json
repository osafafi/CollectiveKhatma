{"page":604,"juz":30,"surahIds":[112,113,114],"ayat":[{"surah":112,"ayah":1,"text":"قُلْ هُوَ ٱللَّهُ أَحَدٌ"},{"surah":112,"ayah":2,"text":"ٱللَّهُ ٱلصَّمَدُ"},{"surah":112,"ayah":3,"text":"لَمْ يَلِدْ وَلَمْ يُولَدْ"},{"surah":112,"ayah":4,"text":"وَلَمْ يَكُن لَّهُۥ كُفُوًا أَحَدٌۢ"},{"surah":113,"ayah":1,"text":"قُلْ أَعُوذُ بِرَبِّ ٱلْفَلَقِ"},{"surah":113,"ayah":2,"text":"مِن شَرِّ مَا خَلَقَ"},{"surah":113,"ayah":3,"text":"وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ"},{"surah":113,"ayah":4,"text":"وَمِن شَرِّ ٱلنَّفَّـٰثَـٰتِ فِى ٱلْعُقَدِ"},{"surah":113,"ayah":5,"text":"وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ"},{"surah":114,"ayah":1,"text":"قُلْ أَعُوذُ بِرَبِّ ٱلنَّاسِ"},{"surah":114,"ayah":2,"text":"مَلِكِ ٱلنَّاسِ"},{"surah":114,"ayah":3,"text":"إِلَـٰهِ ٱلنَّاسِ"},{"surah":114,"ayah":4,"text":"مِن شَرِّ ٱلْوَسْوَاسِ ٱلْخَنَّاسِ"},{"surah":114,"ayah":5,"text":"ٱلَّذِى يُوَسْوِسُ فِى صُدُورِ ٱلنَّاسِ"},{"surah":114,"ayah":6,"text":"مِنَ ٱلْجِنَّةِ وَٱلنَّاسِ"}]}